  "themes": {
    "1": {
      "name": "Week 1: Media en communicatie",
      "emoji": "📰",
      "vocabulary": [
        {
          "word": "het abonnement",
          "definition": "een vast bedrag dat je betaalt om gebruik te maken van bijvoorbeeld tv of krant"
        },
        {
          "word": "het artikel",
          "definition": "een verhaal in een krant of blad"
        },
        {
          "word": "communiceren",
          "definition": "met andere mensen praten of chatten"
        },
        {
          "word": "het dagblad",
          "definition": "een krant die elke dag verschijnt"
        },
        {
          "word": "doorvragen",
          "definition": "vragen blijven stellen om meer over iets te weten te komen"
        },
        {
          "word": "het feit",
          "definition": "iets dat waar is"
        },
        {
          "word": "informeren",
          "definition": "ergens vragen over stellen of iets vertellen aan iemand"
        },
        {
          "word": "de journalist",
          "definition": "iemand die stukken schrijft over het nieuws"
        },
        {
          "word": "het krantenbericht",
          "definition": "een stukje tekst in de krant"
        },
        {
          "word": "de krantenkop",
          "definition": "de titel van een bericht in de krant"
        },
        {
          "word": "de spotprent",
          "definition": "een tekening waarin iets of iemand belachelijk wordt gemaakt"
        },
        {
          "word": "de voorpagina",
          "definition": "de eerste bladzijde van een krant"
        }
      ]
    },
